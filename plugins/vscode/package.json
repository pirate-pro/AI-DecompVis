{
  "name": "aidecompvis-vscode",
  "displayName": "AI-DecompVis",
  "description": "Thin VS Code adapter for local AI-DecompVis backend",
  "version": "0.1.0",
  "publisher": "aidecompvis",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:aidecompvis.connectSession",
    "onCommand:aidecompvis.selectProjectSession",
    "onCommand:aidecompvis.searchFunction",
    "onCommand:aidecompvis.showExplanation",
    "onCommand:aidecompvis.addAnnotation",
    "onCommand:aidecompvis.addBookmark",
    "onCommand:aidecompvis.applyNoReturnConstraint",
    "onCommand:aidecompvis.applyValueRangeConstraint",
    "onCommand:aidecompvis.applyTypeOverrideConstraint",
    "onView:aidecompvis.functions"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aidecompvis.connectSession",
        "title": "AI-DecompVis: Connect Session"
      },
      {
        "command": "aidecompvis.selectProjectSession",
        "title": "AI-DecompVis: Select Project Session"
      },
      {
        "command": "aidecompvis.searchFunction",
        "title": "AI-DecompVis: Search Functions"
      },
      {
        "command": "aidecompvis.showFunctionSummary",
        "title": "AI-DecompVis: Show Function Summary"
      },
      {
        "command": "aidecompvis.showExplanation",
        "title": "AI-DecompVis: Show Explanation"
      },
      {
        "command": "aidecompvis.addAnnotation",
        "title": "AI-DecompVis: Add Annotation"
      },
      {
        "command": "aidecompvis.addBookmark",
        "title": "AI-DecompVis: Add Bookmark"
      },
      {
        "command": "aidecompvis.applyNoReturnConstraint",
        "title": "AI-DecompVis: Apply No-Return Constraint"
      },
      {
        "command": "aidecompvis.applyValueRangeConstraint",
        "title": "AI-DecompVis: Apply Value-Range Constraint"
      },
      {
        "command": "aidecompvis.applyTypeOverrideConstraint",
        "title": "AI-DecompVis: Apply Type-Override Constraint"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "aidecompvis.functions",
          "name": "AI-DecompVis Functions"
        }
      ]
    },
    "configuration": {
      "title": "AI-DecompVis",
      "properties": {
        "aidecompvis.backendUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8000",
          "description": "Local AI-DecompVis backend URL"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p ."
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.8.2"
  }
}
